# DataRobot credentials for local e2e skill testing
# Copy to .env and fill in your values (never commit .env)

DATAROBOT_ENDPOINT=https://app.datarobot.com/api/v2
DATAROBOT_API_TOKEN=your_api_token_here
# Deployment ID for the live MCP registration e2e test (test_register_mcp_tool_live.py)
E2E_TEST_DEPLOYMENT_ID=your_deployment_id_here
